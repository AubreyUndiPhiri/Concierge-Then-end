<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        :root { 
            --accent: #e1b12c; 
            --accent-glow: rgba(225, 177, 44, 0.4);
            --bg-dark: #0a0a0a; 
            --glass: rgba(255, 255, 255, 0.03); 
            --glass-thick: rgba(20, 20, 20, 0.95);
            --border: rgba(255, 255, 255, 0.1); 
            --text: #ffffff; 
            --success: #2ecc71; 
            --danger: #ff4757; 
        }
        
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        html, body { height: 100%; margin: 0; padding: 0; background: var(--bg-dark); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; overflow-x: hidden; }

        body::before {
            content: ""; position: fixed; inset: 0;
            background-image: url('https://www.transparenttextures.com/patterns/leopard/60-opacity.png');
            background-size: 400px; opacity: 0.05; pointer-events: none; z-index: 0;
        }

        /* LOGIN UI */
        #login-overlay { position: fixed; inset: 0; background: var(--bg-dark); z-index: 20000; display: flex; align-items: center; justify-content: center; }
        .login-card { width: 90%; max-width: 360px; padding: 60px 40px; border-radius: 40px; background: var(--glass-thick); border: 1px solid var(--border); backdrop-filter: blur(20px); text-align: center; box-shadow: 0 40px 100px rgba(0,0,0,0.8); animation: slideUp 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); }
        .login-field { margin-bottom: 15px; }
        .login-field input { 
            width: 100%; padding: 18px 25px; background: rgba(255,255,255,0.03); 
            border: 1px solid var(--border); border-radius: 20px; color: white; 
            font-size: 15px; outline: none; transition: 0.3s; text-align: center;
        }
        .login-field input:focus { border-color: var(--accent); background: rgba(225,177,44,0.05); }

        /* HEADER */
        .nav-bar { display: flex; flex-direction: column; background: var(--glass); margin: 15px; border-radius: 25px; border: 1px solid var(--border); backdrop-filter: blur(10px); padding: 15px; gap: 15px; }
        .nav-top-row { display: flex; justify-content: flex-start; width: 100%; }
        .nav-bottom-row { display: flex; justify-content: space-between; align-items: center; width: 100%; }
        .nav-logo { height: 32px; margin-left: 5px; }

        .tab-btn { padding: 10px; cursor: pointer; background: transparent; border: none; border-radius: 15px; color: #777; transition: 0.4s; display: flex; align-items: center; justify-content: center; }
        .tab-btn.active { background: var(--accent); color: #000; box-shadow: 0 0 15px var(--accent-glow); }

        /* MODALS & CARDS */
        .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(15px); z-index: 10000; display: none; align-items: center; justify-content: center; padding: 20px; }
        .modal-box { background: #121212; border: 1px solid var(--border); border-radius: 35px; width: 100%; max-width: 500px; box-shadow: 0 50px 100px rgba(0,0,0,0.5); overflow-y: auto; max-height: 85vh; }
        .modal-body { padding: 30px; }
        
        .settings-card { background: rgba(255,255,255,0.03); border-radius: 24px; padding: 20px; border: 1px solid var(--border); margin-bottom: 20px; }
        .settings-title { font-size: 11px; font-weight: 800; color: var(--accent); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 15px; display: block; }

        .staff-item { padding: 15px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .staff-header { display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
        .status-dot { width: 8px; height: 8px; border-radius: 50%; background: #333; margin-right: 8px; display: inline-block; }
        .status-dot.online { background: var(--success); box-shadow: 0 0 10px var(--success); }
        
        .role-chip { padding: 5px 12px; border: 1px solid var(--border); border-radius: 12px; font-size: 9px; cursor: pointer; margin-right: 4px; margin-top: 8px; display: inline-block; transition: 0.2s; }
        .role-chip.selected { background: var(--accent); color: #000; border-color: var(--accent); }

        /* KPI ROW */
        #admin-kpi-row { display: none; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 0 15px 15px; }
        .kpi-card { background: var(--glass); border: 1px solid var(--border); padding: 15px 5px; border-radius: 22px; text-align: center; }
        .kpi-val { display: block; font-size: 22px; font-weight: 900; color: var(--accent); }

        .btn-action { width: 100%; border: none; padding: 16px; border-radius: 20px; cursor: pointer; font-weight: 800; color: #000; background: var(--accent); transition: 0.3s; }
        .btn-ghost { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: #fff; padding: 12px; border-radius: 15px; cursor: pointer; width: 100%; font-size: 13px; margin-top: 10px; }
        .btn-danger { background: rgba(255, 71, 87, 0.1) !important; color: #ff4757 !important; border: 1px solid rgba(255, 71, 87, 0.2) !important; }

        textarea, select, input { width: 100%; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 18px; color: white; padding: 15px; margin: 10px 0; font-size: 14px; outline: none; }

        .order-card { background: var(--glass); border: 1px solid var(--border); border-radius: 25px; padding: 20px; margin-bottom: 15px; }

        @keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    </style>
</head>
<body>

    <div id="modal-overlay" class="modal-overlay">
        <div class="modal-box">
            <div id="modal-content-area" class="modal-body"></div>
            <div id="modal-footer" class="modal-footer" style="padding: 0 30px 30px; display: flex; gap: 10px;">
                <button class="btn-ghost" onclick="closeModal()">Close</button>
                <button id="modal-confirm-btn" class="btn-action" style="display:none; flex:2;">Confirm</button>
            </div>
        </div>
    </div>

    <div id="login-overlay">
        <div class="login-card">
            <img src="https://static.wixstatic.com/media/95f42d_32028d72cfaa4b55b69b00488536c360~mv2.png" style="height:45px; margin-bottom:40px;">
            <div class="login-field"><input type="email" id="email" placeholder="Email Address"></div>
            <div class="login-field"><input type="password" id="pass" placeholder="Password"></div>
            <button class="btn-action" onclick="login()" style="margin-top:20px; box-shadow: 0 15px 30px var(--accent-glow);">Sign In</button>
        </div>
    </div>

    <div id="main-content" style="display:none; padding-bottom: 50px;">
        <nav class="nav-bar">
            <div class="nav-top-row"><img src="https://static.wixstatic.com/media/95f42d_32028d72cfaa4b55b69b00488536c360~mv2.png" class="nav-logo"></div>
            <div class="nav-bottom-row">
                <div id="tabs-container" style="display:flex; gap:8px;">
                    <button id="tab-Kitchen" class="tab-btn" onclick="handleTabSwitch('Kitchen', this)"><span class="material-icons-outlined">restaurant</span></button>
                    <button id="tab-Spa" class="tab-btn" onclick="handleTabSwitch('Spa', this)"><span class="material-icons-outlined">spa</span></button>
                    <button id="tab-Activities" class="tab-btn" onclick="handleTabSwitch('Activities', this)"><span class="material-icons-outlined">explore</span></button>
                    <button id="tab-Enroll" class="tab-btn" style="display:none;" onclick="handleTabSwitch('Enroll', this)"><span class="material-icons-outlined">person_add</span></button>
                </div>
                <button class="tab-btn" onclick="openSettings()"><span class="material-icons-outlined">settings</span></button>
            </div>
        </nav>

        <div id="admin-kpi-row">
            <div class="kpi-card"><span id="kpi-convos" class="kpi-val">0</span><span style="font-size:8px; opacity:0.5; text-transform:uppercase;">Volume</span></div>
            <div class="kpi-card"><span id="kpi-rating" class="kpi-val">0.0</span><span style="font-size:8px; opacity:0.5; text-transform:uppercase;">Score</span></div>
            <div class="kpi-card"><span id="kpi-feedback" class="kpi-val">0</span><span style="font-size:8px; opacity:0.5; text-transform:uppercase;">Reviews</span></div>
        </div>

        <div id="tab-content-wrapper" style="display: none;">
            <div id="dept-controls" style="padding: 0 15px;">
                <div id="avail-card" class="settings-card">
                    <span class="settings-title" id="dept-ai-label">AI Availability</span>
                    <textarea id="outOfStockText" rows="3" placeholder="Unavailable items for today..."></textarea>
                    <button class="btn-action" style="padding: 12px; font-size: 13px;" onclick="customConfirm('Sync AI?', 'Concierge responses will update immediately.', 'saveAvailability')">Sync Knowledge</button>
                </div>
                
                <div id="activity-price-controls" class="settings-card" style="display:none;">
                    <span class="settings-title">Pricing Updates (USD)</span>
                    <textarea id="activityPriceText" rows="2" placeholder="Sunset Cruise $95..."></textarea>
                    <button class="btn-action" style="padding: 12px; font-size: 13px; background:#fff;" onclick="customConfirm('Update Prices?', 'Live activity rates will change.', 'saveActivityPrices')">Sync Prices</button>
                </div>

                <div id="enrollment-section" class="settings-card" style="display:none;">
                    <span class="settings-title">Register Member</span>
                    <input type="text" id="new-staff-name" placeholder="Full Name">
                    <input type="email" id="new-staff-email" placeholder="Work Email">
                    <input type="password" id="new-staff-pass" placeholder="Password">
                    <div id="enroll-role-selector" style="margin: 10px 0;">
                        <div class="role-chip" data-role="Kitchen" onclick="toggleEnrollRole(this)">Kitchen</div>
                        <div class="role-chip" data-role="Spa" onclick="toggleEnrollRole(this)">Spa</div>
                        <div class="role-chip" data-role="Activities" onclick="toggleEnrollRole(this)">Activities</div>
                        <div class="role-chip" data-role="Admin" onclick="toggleEnrollRole(this)">Admin</div>
                    </div>
                    <button class="btn-action" onclick="finalizeEnrollment()">Register Staff</button>
                </div>
            </div>

            <div id="display-area" style="padding: 0 15px;">
                <div id="active-list"></div>
                <div class="section-label" style="margin: 40px 5px 10px; font-size: 10px; opacity: 0.4; text-transform: uppercase;">Recently Fulfilled</div>
                <div id="history-list"></div>
            </div>
        </div>
    </div>

    <script>
        let isAdmin = false;
        let currentUserEmail = "";
        let allStaffList = [];
        let selectedEnrollRoles = [];
        let editRolesBuffer = [];

        window.onload = () => { window.parent.postMessage({ type: "ready" }, "*"); };

        function closeModal() { document.getElementById('modal-overlay').style.display = 'none'; }

        function showSuccessUI(msg, isWarning = false) {
            const area = document.getElementById('modal-content-area');
            const icon = isWarning ? 'report_problem' : 'check_circle';
            const color = isWarning ? 'var(--danger)' : 'var(--success)';
            const title = isWarning ? 'Warning' : 'Royal Success';

            area.innerHTML = `
                <div style="text-align:center; padding:20px;">
                    <span class="material-icons-outlined" style="font-size:64px; color:${color}; margin-bottom:15px;">${icon}</span>
                    <h3 style="color:${color};">${title}</h3>
                    <p style="opacity:0.7; font-size:14px;">${msg}</p>
                </div>`;
            document.getElementById('modal-confirm-btn').style.display = 'none';
            document.getElementById('modal-overlay').style.display = 'flex';
            setTimeout(closeModal, 2200);
        }

        function customConfirm(title, message, actionType, extraData = null) {
            const area = document.getElementById('modal-content-area');
            const conf = document.getElementById('modal-confirm-btn');
            
            area.innerHTML = `
                <h3 style="color:var(--accent); margin-bottom:10px;">${title}</h3>
                <p style="opacity:0.8; font-size:14px;">${message}</p>`;
            
            conf.style.display = 'block';
            conf.innerText = actionType.includes('delete') ? "Yes, Delete" : "Confirm Sync";
            conf.className = actionType.includes('delete') ? "btn-action btn-danger" : "btn-action";

            conf.onclick = () => {
                if(actionType === 'saveAvailability') {
                    window.parent.postMessage({ type: actionType, text: document.getElementById('outOfStockText').value }, "*");
                    showSuccessUI("Availability updated.");
                }
                if(actionType === 'saveActivityPrices') {
                    window.parent.postMessage({ type: actionType, text: document.getElementById('activityPriceText').value }, "*");
                    showSuccessUI("Pricing synced.");
                }
                if(actionType === 'saveDrivers') {
                    const driverData = document.getElementById('driver-input').value;
                    window.parent.postMessage({ type: "saveDrivers", text: driverData }, "*");
                    showSuccessUI("Driver list updated.");
                }
                if(actionType === 'updateStaffMember') {
                    finalizeStaffEdit(extraData);
                    showSuccessUI("Member profile updated.");
                }
                if(actionType === 'deleteStaffMember') {
                    window.parent.postMessage({ type: "deleteStaff", id: extraData }, "*");
                    showSuccessUI("Member removed.", true);
                }
                if(!actionType.includes('enroll')) closeModal();
            };
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        function login() {
            const email = document.getElementById('email').value;
            const password = document.getElementById('pass').value;
            window.parent.postMessage({ type: "staffLogin", email, password }, "*");
        }

        function openSettings() {
            window.parent.postMessage({ type: "getStaffList" }, "*");
            window.parent.postMessage({ type: "getDriverInfo" }, "*");
            const content = document.getElementById('modal-content-area');
            content.innerHTML = `
                <h2 style="margin:0 0 25px 0; font-size:22px; font-weight:900; color:var(--accent);">Royal Settings</h2>
                ${isAdmin ? `
                <div class="settings-card">
                    <span class="settings-title">AI Driver Management</span>
                    <textarea id="driver-input" rows="3" placeholder="Enter driver contacts..."></textarea>
                    <button class="btn-action" style="padding:12px; font-size:12px;" onclick="customConfirm('Update Drivers?', 'Drivers will be visible to guests immediately.', 'saveDrivers')">Sync Drivers</button>
                </div>` : ''}
                <div class="settings-card">
                    <span class="settings-title">Staff Directory</span>
                    <div id="staff-settings-list" style="max-height:250px; overflow-y:auto;">Loading...</div>
                </div>
                <button class="btn-ghost" onclick="window.parent.postMessage({type:'refreshKPIs'}, '*'); closeModal();">Refresh Analytics</button>
                <button class="btn-ghost btn-danger" onclick="window.parent.postMessage({ type: 'staffLogout' }, '*');">Sign Out</button>
            `;
            document.getElementById('modal-confirm-btn').style.display = 'none';
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        function editStaffInfo(id) {
            const staff = allStaffList.find(s => s._id === id);
            if(!staff) return;
            editRolesBuffer = [...(staff.roles || [])];
            
            const area = document.getElementById('modal-content-area');
            area.innerHTML = `
                <h3 style="color:var(--accent); margin-bottom:10px;">Edit Member</h3>
                <p style="font-size:11px; opacity:0.5; margin-bottom:20px;">Staff ID: ${id}</p>
                <input type="text" id="edit-name" value="${staff.firstName}" placeholder="Name">
                <input type="email" id="edit-email" value="${staff.email}" placeholder="Email">
                <input type="password" id="edit-pass" value="${staff.password}" placeholder="Update Password">
                
                <span class="settings-title" style="margin-top:20px;">Departments</span>
                <div id="edit-role-selector" style="margin-bottom:25px;">
                    ${["Kitchen", "Spa", "Activities", "Admin"].map(r => `
                        <div class="role-chip ${editRolesBuffer.includes(r) ? 'selected' : ''}" 
                             data-role="${r}" onclick="toggleEditRole(this)">${r}</div>
                    `).join('')}
                </div>

                <button class="btn-ghost btn-danger" onclick="customConfirm('Confirm Deletion?', 'Warning: You are deleting this member. This cannot be undone.', 'deleteStaffMember', '${id}')">Delete Profile</button>
            `;
            
            const conf = document.getElementById('modal-confirm-btn');
            conf.style.display = 'block';
            conf.className = "btn-action";
            conf.innerText = "Save Changes";
            conf.onclick = () => {
                const updatedData = {
                    id: staff._id,
                    firstName: document.getElementById('edit-name').value,
                    email: document.getElementById('edit-email').value,
                    password: document.getElementById('edit-pass').value,
                    roles: editRolesBuffer
                };
                customConfirm('Save Updates?', 'Confirm modifications to this staff profile.', 'updateStaffMember', updatedData);
            };
        }

        function toggleEditRole(el) {
            const role = el.getAttribute('data-role');
            if(editRolesBuffer.includes(role)) {
                editRolesBuffer = editRolesBuffer.filter(r => r !== role);
                el.classList.remove('selected');
            } else {
                editRolesBuffer.push(role);
                el.classList.add('selected');
            }
        }

        function finalizeStaffEdit(data) { window.parent.postMessage({ type: "updateStaffInfo", data: data }, "*"); }

        function toggleEnrollRole(el) {
            const role = el.getAttribute('data-role');
            if(selectedEnrollRoles.includes(role)) {
                selectedEnrollRoles = selectedEnrollRoles.filter(r => r !== role);
                el.classList.remove('selected');
            } else {
                selectedEnrollRoles.push(role);
                el.classList.add('selected');
            }
        }

        function finalizeEnrollment() {
            const name = document.getElementById('new-staff-name').value;
            const emailInput = document.getElementById('new-staff-email').value.trim();
            const pass = document.getElementById('new-staff-pass').value;

            if (!emailInput.includes('@')) { showSuccessUI('Please enter a valid email.', true); return; }
            
            const isDuplicate = allStaffList.some(s => s.email.toLowerCase() === emailInput.toLowerCase());
            if (isDuplicate) {
                showSuccessUI('Primary Key Error: This email is already registered.', true);
                return;
            }
            if (selectedEnrollRoles.length === 0) { showSuccessUI('Assign at least one department.', true); return; }

            const data = { firstName: name, email: emailInput, password: pass, roles: selectedEnrollRoles };
            
            customConfirm('Register Member?', `Assigned to: ${selectedEnrollRoles.join(', ')}`, 'enrollStaff_Submit');
            
            document.getElementById('modal-confirm-btn').onclick = () => {
                window.parent.postMessage({ type: "enrollStaff", staffData: data }, "*");
                document.getElementById('new-staff-name').value = "";
                document.getElementById('new-staff-email').value = "";
                document.getElementById('new-staff-pass').value = "";
                selectedEnrollRoles = [];
                document.querySelectorAll('#enroll-role-selector .role-chip').forEach(c => c.classList.remove('selected'));
                showSuccessUI("New member registered successfully.");
            };
        }

        function handleTabSwitch(dept, btn) {
            document.getElementById('tab-content-wrapper').style.display = 'block';
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            const avail = document.getElementById('avail-card');
            const enroll = document.getElementById('enrollment-section');
            const priceBox = document.getElementById('activity-price-controls');

            if(dept === 'Enroll') {
                avail.style.display = 'none'; enroll.style.display = 'block'; priceBox.style.display = 'none';
            } else {
                avail.style.display = 'block'; enroll.style.display = 'none';
                priceBox.style.display = (dept === 'Activities') ? 'block' : 'none';
                document.getElementById('dept-ai-label').innerText = `AI ${dept} Context`;
                window.parent.postMessage({ type: "filter", department: dept }, "*");
            }
        }

        window.onmessage = (event) => {
            const d = event.data;
            if (d.type === "showLogin") document.getElementById('login-overlay').style.display = 'flex';
            
            if (d.type === "setUser") {
                document.getElementById('login-overlay').style.display = 'none';
                document.getElementById('main-content').style.display = 'block';
                document.getElementById('tab-content-wrapper').style.display = 'none';
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));

                isAdmin = d.isAdmin;
                currentUserEmail = d.user.email;
                if(isAdmin) {
                    document.getElementById('tab-Enroll').style.display = 'flex';
                    document.getElementById('admin-kpi-row').style.display = 'grid';
                }
                window.scrollTo(0,0);
            }

            if (d.type === "loadDrivers") {
                const input = document.getElementById('driver-input');
                if(input) input.value = d.text || "";
            }

            if (d.type === "staffListUpdate") {
                allStaffList = d.payload;
                const container = document.getElementById('staff-settings-list');
                if(container) {
                    container.innerHTML = d.payload.map(s => `
                        <div class="staff-item">
                            <div class="staff-header" onclick="${isAdmin ? `editStaffInfo('${s._id}')` : ''}">
                                <div>
                                    <span class="status-dot ${s.email === currentUserEmail ? 'online' : ''}"></span>
                                    <span style="font-weight:bold; font-size:14px;">${s.firstName}</span>
                                    <div style="font-size:10px; opacity:0.4; margin-top:2px;">${s.email}</div>
                                </div>
                                ${isAdmin ? '<span class="material-icons-outlined" style="font-size:16px; opacity:0.3;">edit</span>' : ''}
                            </div>
                        </div>`).join('');
                }
            }

            if (d.type === "loadKPIs") {
                document.getElementById('kpi-convos').innerText = d.data.totalConversations || 0;
                document.getElementById('kpi-rating').innerText = d.data.averageRating || "0.0";
                document.getElementById('kpi-feedback').innerText = d.data.totalFeedback || 0;
            }

            if (d.type === "updateOrders") renderList('active-list', d.orders);
            if (d.type === "loadAvailability") document.getElementById('outOfStockText').value = d.text || "";
            if (d.type === "loadActivityPrices") document.getElementById('activityPriceText').value = d.text || "";
            
            // Primary handle for parent-triggered alerts
            if (d.type === "alert") showSuccessUI(d.msg, d.msg.toLowerCase().includes('delete') || d.msg.toLowerCase().includes('error'));
        };

        function renderList(targetId, orders) {
            const container = document.getElementById(targetId);
            if(!orders || orders.length === 0) { 
                container.innerHTML = `<div style="padding:60px; text-align:center; opacity:0.2; font-size:13px;">Queue is clear.</div>`; 
                return; 
            }
            container.innerHTML = orders.map(o => `
                <div class="order-card">
                    <div style="font-weight:900; color:var(--accent); font-size:18px; margin-bottom:5px;">Room ${o.roomName || o.roomNumber}</div>
                    <div style="font-size:10px; opacity:0.4; margin-bottom:20px;">Requested at ${new Date(o.timestamp || o._createdDate).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</div>
                    <button class="btn-action" style="padding:12px; font-size:12px;" onclick="window.parent.postMessage({type:'notifyReady', id:'${o._id}', dept:'${o.requestType}', room:'${o.roomNumber}'}, '*')">Fulfill Task</button>
                </div>`).join('');
        }
    </script>
</body>
</html>
